# AirTerm Relay Server Configuration
# Copy this file to .env and fill in the values

# REQUIRED: Secret key for JWT token signing (min 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Server port (default: 3000)
PORT=3000

# Database file path (default: ./airterm.db)
DB_PATH=./airterm.db

# Database encryption key for SQLCipher (recommended for production)
# Generate with: openssl rand -hex 32
# DB_ENCRYPTION_KEY=

# Pair code time-to-live in seconds (default: 300 = 5 minutes)
PAIR_CODE_TTL=300

# Domain name for the relay server
DOMAIN=relay.airterm.ai
