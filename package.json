{
  "name": "airterm",
  "private": true,
  "description": "Remote control for Claude Code CLI sessions",
  "type": "module",
  "scripts": {
    "dev:server": "pnpm --filter @airterm/server dev",
    "dev:web": "pnpm --filter @airterm/web dev",
    "build": "pnpm -r build",
    "build:server": "pnpm --filter @airterm/server build",
    "build:web": "pnpm --filter @airterm/web build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.0.0"
  }
}
